{
  "description": "Review loop and Ralph loop stop hooks",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/stop-hook.sh",
            "timeout": 900,
            "statusMessage": "Review loop: checking phase..."
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/ralph-stop-hook.sh",
            "timeout": 900,
            "statusMessage": "Ralph loop: checking phase..."
          }
        ]
      }
    ]
  }
}
